---
// Profile 卡片组件 - 参考 Fuwari 风格
// 显示站点头像、名称、描述和社交链接

interface SocialLink {
  name: string;
  url: string;
  icon: string;
}

interface Props {
  // 可选的社交链接配置
  socials?: SocialLink[];
}

// 默认社交链接
const defaultSocials: SocialLink[] = [
  {
    name: 'GitHub',
    url: 'https://github.com/tech-MeLD/LiteASCII',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>'
  },
  {
    name: 'RSS',
    url: '/rss.xml',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>'
  }
];

const { socials = defaultSocials } = Astro.props;
---

<div class="profile-card">
  <!-- 头像 -->
  <div class="profile-avatar">
    <a href="https://github.com/tech-MeLD/LiteASCII" target="_blank" rel="noopener noreferrer" class="avatar-link" title="GitHub">
      <img src="/ProfileImage.png" alt="tech_MeLD" class="avatar-img" />
    </a>
  </div>
  
  <!-- 名称 -->
  <h3 class="profile-name">
    <a href="https://github.com/tech-MeLD/LiteASCII" target="_blank" rel="noopener noreferrer" class="name-link">tech_MeLD</a>
  </h3>
  
  <!-- 描述 -->
  <p class="profile-desc">Build and Design</p>
  
  <!-- 社交链接图标 -->
  <div class="social-links">
    {socials.map((social) => (
      <a 
        href={social.url} 
        class="social-link" 
        target={social.url.startsWith('http') ? '_blank' : '_self'}
        rel={social.url.startsWith('http') ? 'noopener noreferrer' : ''}
        title={social.name}
        aria-label={social.name}
      >
        <span class="social-icon" set:html={social.icon} />
      </a>
    ))}
  </div>
</div>

<style>
  .profile-card {
    text-align: center;
    padding: 1.5rem 1rem;
  }

  /* 头像 */
  .profile-avatar {
    width: 80px;
    height: 80px;
    margin: 0 auto 1rem;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--red);
    padding: 3px;
    transition: all 0.3s ease;
  }
  
  .profile-avatar:hover {
    transform: scale(1.05);
    box-shadow: 0 0 20px rgba(255, 94, 77, 0.2);
  }
  
  .avatar-link {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
  }
  
  .avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    background: var(--bg-2);
    transition: transform 0.3s ease;
  }
  
  .avatar-link:hover .avatar-img {
    transform: scale(1.1);
  }

  /* 名称 */
  .profile-name {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  
  .name-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .name-link:hover {
    color: var(--red);
  }

  /* 描述 */
  .profile-desc {
    font-size: 0.85rem;
    color: var(--text-3);
    margin: 0 0 1.25rem;
    line-height: 1.5;
    opacity: 0.9;
  }

  /* 社交链接 */
  .social-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
  }
  
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--bg-2);
    border: 1px solid var(--border);
    color: var(--text-3);
    transition: all 0.2s ease;
  }
  
  .social-link:hover {
    background: var(--red-faint);
    border-color: var(--red);
    color: var(--red);
    transform: translateY(-2px);
  }
  
  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .social-icon :global(svg) {
    width: 18px;
    height: 18px;
  }

  /* 移动端适配 */
  @media (max-width: 900px) {
    .profile-card {
      padding: 1rem;
    }
    
    .profile-avatar {
      width: 64px;
      height: 64px;
      margin-bottom: 0.75rem;
    }
    
    .profile-name {
      font-size: 1.1rem;
    }
    
    .profile-desc {
      font-size: 0.8rem;
      margin-bottom: 1rem;
    }
    
    .social-link {
      width: 32px;
      height: 32px;
    }
    
    .social-icon :global(svg) {
      width: 16px;
      height: 16px;
    }
  }
</style>