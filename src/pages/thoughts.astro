---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.svelte';
import Footer from '../components/layout/Footer.svelte';
import PageHeader from '../components/layout/PageHeader.svelte';
import NoteCard from '../components/features/NoteCard.svelte';
import { getCollection } from 'astro:content';
import { extractTitle, noteSlug, formatDate } from '../lib/core/note-logic';

const allNotes = await getCollection('notes');
const thoughts = allNotes
  .filter((n) => n.data.category === 'thoughts')
  .sort((a, b) => {
    const da = a.data.date ? new Date(a.data.date).getTime() : 0;
    const db = b.data.date ? new Date(b.data.date).getTime() : 0;
    return db - da;
  });

const notes = thoughts.map(note => ({
  title: extractTitle(note),
  href: `/notes/${noteSlug(note.id)}`,
  date: formatDate(note.data.date),
  description: note.data.description,
  category: note.data.category,
  tags: note.data.tags || [],
}));
---

<Layout title="Thoughts · LiteASCII">
  <Header client:load />
  
  <main class="pt-[calc(52px+2.5rem)] max-w-3xl mx-auto px-6 pb-16">
    <PageHeader 
      client:load
      title="Thoughts" 
      subtitle={`${thoughts.length} 篇随想 · 记录灵光一闪的瞬间`} 
    />
    
    <div class="flex flex-col gap-4">
      {notes.map((note) => (
        <NoteCard
          client:load
          title={note.title}
          href={note.href}
          date={note.date}
          description={note.description}
          category={note.category}
          tags={note.tags}
        />
      ))}
    </div>
    
    {thoughts.length === 0 && (
      <div class="text-center py-12 border border-dashed border-border-color rounded-xl">
        <p class="text-text-muted">暂无随想笔记</p>
        <p class="text-sm text-text-muted mt-2">
          请在 Obsidian 中为笔记添加 <code class="text-primary bg-primary-faint px-1.5 py-0.5 rounded">category: thoughts</code>
        </p>
      </div>
    )}
  </main>
  
  <Footer />
</Layout>