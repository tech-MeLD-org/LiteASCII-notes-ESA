---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.svelte';
import NoteExplorerSidebar from '../../components/NoteExplorerSidebar.svelte';
import Footer from '../../components/Footer.astro';
import { isVisibleNote, pathToSlug, getNoteTitle } from '../../utils/note-logic';

export async function getStaticPaths() {
  const noteEntries = await getCollection('notes');
  const validNotes = noteEntries.filter(isVisibleNote);
  return validNotes.map(entry => ({
    params: { slug: pathToSlug(entry.id) },
    props: { entry, allNotes: validNotes },
  }));
}

const { entry, allNotes } = Astro.props;
// render(entry) 返回 Content 组件和标题数组
const { Content, headings } = await render(entry); 
const title = getNoteTitle(entry);
const currentSlug = pathToSlug(entry.id);
---

<Layout title={`${title} · LiteASCII`}>
  <Navigation client:load />

  <div class="three-column-layout">
    <NoteExplorerSidebar client:load allNotes={allNotes} currentSlug={currentSlug} />

    <main class="content-column">
      <article class="prose">
        <header class="note-header">
          <h1 class="note-title">{title}</h1>
          <div class="note-tags">
            {entry.data.tags?.map((tag: string) => (
              <a href={`/tags/${tag}`} class="tag">#{tag}</a>
            ))}
          </div>
        </header>
        <section class="markdown-body">
          <Content />
        </section>
      </article>
      <Footer />
    </main>

    <aside class="toc-column">
      <div class="toc-inner">
        <div class="toc-label">ON THIS PAGE</div>
        <nav id="toc-nav">
          {headings
            .filter(h => h.depth >= 1 && h.depth <= 4)
            .map((h) => (
              <a 
                href={`#${h.slug}`} 
                class={`toc-item d-${h.depth}`} 
                data-slug={h.slug}
              >
                {h.text}
              </a>
            ))
          }
        </nav>
      </div>
    </aside>
  </div>
</Layout>

<script>
  // 1. 禁用滚动高亮 - 根据用户需求，滑动过程不显示高亮
  // 原 IntersectionObserver 代码已移除，只保留点击高亮功能
  
  // 2. 实现点击平滑滚动并立即高亮
  document.querySelectorAll('#toc-nav a').forEach(anchor => {
    anchor.addEventListener('click', (e) => {
      e.preventDefault();
      const targetAnchor = e.currentTarget as HTMLAnchorElement;
      
      // 立即更新高亮状态
      document.querySelectorAll('#toc-nav a').forEach(a => a.classList.remove('active'));
      targetAnchor.classList.add('active');
      
      // 执行平滑滚动
      const targetId = targetAnchor.getAttribute('href')?.slice(1);
      if (targetId) {
        const targetEl = document.getElementById(targetId);
        if (targetEl) {
          const navHeight = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--nav-h')) || 64;
          window.scrollTo({
            top: targetEl.offsetTop - navHeight - 20,
            behavior: 'smooth'
          });
        }
      }
    });
  });
</script>

<style>
  /* ── 核心布局 (禁止重叠) ── */
  .three-column-layout {
    display: grid;
    grid-template-columns: 260px 1fr 240px;
    gap: 0;
    margin-top: var(--nav-h);
    min-height: calc(100vh - var(--nav-h));
    width: 100%;
  }

  @media (max-width: 1200px) {
    .three-column-layout { grid-template-columns: 260px 1fr; }
    .toc-column { display: none; }
  }
  @media (max-width: 900px) {
    .three-column-layout { grid-template-columns: 1fr; }
    :global(.explorer-sidebar) { display: none; }
  }

  .content-column {
    min-width: 0;
    padding: 2rem 3rem;
    display: flex;
    flex-direction: column;
  }

  .markdown-body { flex: 1; line-height: 1.7; }

  /* ── 移除目录区域滚轮样式（用户已全局设置） ── */
  .toc-column {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;     /* Firefox */
  }
  .toc-column::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Opera */
  }

  /* ── 右侧目录样式 & 阶梯缩进 ── */
  .toc-column { padding: 2rem 1rem; overflow-y: auto; height: fit-content; max-height: calc(100vh - var(--nav-h)); position: sticky; top: var(--nav-h); }
  .toc-inner { border-left: 1px solid var(--border); }
  .toc-label { font-size: 0.7rem; font-weight: 700; color: var(--text-3); margin-bottom: 1rem; padding-left: 1rem; }
  
  .toc-item {
    display: block;
    font-size: 0.85rem;
    color: var(--text-3);
    text-decoration: none;
    padding: 0.4rem 0;
    transition: all 0.2s;
    border-left: 2px solid transparent;
    margin-left: -1.5px; /* 覆盖在基准线上 */
    cursor: pointer;
  }

  /* 严格阶梯缩进 */
  .d-2 { padding-left: 1rem; font-weight: 500; }
  .d-3 { padding-left: 2rem; font-size: 0.8rem; }
  .d-4 { padding-left: 3rem; font-size: 0.75rem; }

  /* 亮色展示样式 */
  .toc-item:hover { color: var(--red); }
  .toc-item.active {
    color: var(--red);
    font-weight: 600;
    border-left-color: var(--red);
    background: var(--red-faint);
  }

  /* ── 文章头部 ── */
  .note-header { margin-bottom: 3rem; border-bottom: 1px solid var(--border); padding-bottom: 2rem; }
  .note-title { font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; }
  .tag { font-size: 0.8rem; color: var(--red); background: var(--red-faint); padding: 0.2rem 0.5rem; border-radius: 4px; text-decoration: none; }
</style>