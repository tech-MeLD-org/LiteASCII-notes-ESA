---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Navigation from '../../components/Navigation.svelte';
// 导入统一的逻辑
import { isVisibleNote, pathToSlug, getNoteTitle } from '../../utils/note-logic';

export async function getStaticPaths() {
  const noteEntries = await getCollection('notes');
  // 使用统一的过滤逻辑，确保不生成附件页面
  const validNotes = noteEntries.filter(isVisibleNote);

  return validNotes.map(entry => ({
    // 使用统一的 Slug 转换函数，确保 URL 与图谱 href 完全一致
    params: { slug: pathToSlug(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// 使用统一的标题提取逻辑
const title = getNoteTitle(entry);
---

<Layout title={`${title} · LiteASCII`}>
  <Navigation client:load />

  <main class="note-container">
    <article class="prose">
      <header class="note-header">
        <h1 class="note-title">{title}</h1>
        {entry.data.date && (
          <time class="note-date">
            {new Date(entry.data.date).toLocaleDateString('zh-CN')}
          </time>
        )}
        
        {entry.data.tags && (
          <div class="note-tags">
            {entry.data.tags.map((tag: string) => (
              <span class="tag-item">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <hr class="header-divider" />

      <section class="markdown-content">
        <Content />
      </section>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .note-container {
    padding-top: var(--nav-h);
    max-width: 800px;
    margin: 0 auto;
    padding-inline: 1.5rem;
    padding-bottom: 5rem;
  }

  .note-header {
    margin-top: 3rem;
    margin-bottom: 2rem;
  }

  .note-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .note-date {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-3);
  }

  /* 标签样式：遵循主题颜色，非点击状态 */
  .note-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag-item {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-2);
    font-family: var(--font-mono);
  }

  .header-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  /* 针对渲染后的 Markdown 内容进行排版优化 */
  .markdown-content {
    line-height: 1.8;
    color: var(--text-2);
  }
</style>