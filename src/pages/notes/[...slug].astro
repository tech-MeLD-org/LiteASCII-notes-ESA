---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.svelte';
import Footer from '../../components/Footer.astro';
import Tag from '../../components/Tag.svelte'; // 【新增】导入统一组件
import { getCollection, render } from 'astro:content';

// ── Static paths ──────────────────────────────────────────────────────────
export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map(note => ({
    params: { slug: note.id.replace(/\.md$/, '') },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content, headings } = await render(note);

// ── Helpers ───────────────────────────────────────────────────────────────
function getTitle(n: any): string {
  if (n.data.title) return n.data.title;
  const match = n.body?.match(/^#\s+(.+)/m);
  if (match) return match[1].trim();
  return n.id.replace(/\.md$/, '').split('/').pop() || 'Untitled';
}

const title = getTitle(note);
const dateStr = note.data.date
  ? new Date(note.data.date).toLocaleDateString('zh-CN', {
      year: 'numeric', month: 'long', day: 'numeric',
    })
  : null;

const toc = headings.filter(h => h.depth === 2 || h.depth === 3);
const hasToc = toc.length > 1;
---

<Layout title={`${title} · LiteASCII`} description={note.data.description}>
  <Navigation client:load />

  <div class:list={['note-layout', { 'with-toc': hasToc }]}>

    {hasToc && (
      <aside class="toc-sidebar">
        <p class="toc-label">目 录</p>
        <nav class="toc-nav">
          {toc.map(h => (
            <a
              href={`#${h.slug}`}
              class:list={['toc-link', h.depth === 2 ? 'h2' : 'h3']}
            >
              {h.text}
            </a>
          ))}
        </nav>
      </aside>
    )}

    <main class="note-main">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/notes">Notes</a>
        {note.id.includes('/') && (
          <>
            <span aria-hidden="true">›</span>
            <span class="bc-folder">{note.id.split('/').slice(0, -1).join('/')}</span>
          </>
        )}
      </nav>

      <article data-pagefind-body>
        <header class="note-header">
          <h1 data-pagefind-meta="title">{title}</h1>
          <div class="note-meta">
            {dateStr && <time>{dateStr}</time>}
            {note.data.tags && note.data.tags.length > 0 && (
              <div class="meta-tags">
                {/* 【修改点】使用 Tag 组件替代原有的 span */}
                {note.data.tags.map((tag: string) => (
                  <Tag name={tag} client:load />
                ))}
              </div>
            )}
          </div>
        </header>

        <div class="prose">
          <Content />
        </div>
      </article>

      <div class="note-footer">
        <a href="/notes" class="back-link">← Back to Notes</a>
      </div>
    </main>
  </div>

  <Footer />
</Layout>

<style>
/* ── 样式部分：删除了 .red-tag，其余保持不变 ── */
.note-layout { padding-top: var(--nav-h); }
.note-main { max-width: 740px; margin: 0 auto; padding: 2rem 1.5rem 3rem; }
.note-layout.with-toc {
  display: grid;
  grid-template-columns: 220px minmax(0, 740px);
  column-gap: 3rem;
  max-width: 1080px;
  margin: 0 auto;
  padding-inline: 1.5rem;
  align-items: start;
}
@media (max-width: 860px) {
  .note-layout.with-toc { display: block; }
  .toc-sidebar { display: none; }
}
.toc-sidebar { position: sticky; top: calc(var(--nav-h) + 2rem); padding-top: 2rem; }
.toc-label { font-size: 0.65rem; font-family: 'Courier New', monospace; color: var(--text-3); margin-bottom: 0.75rem; }
.toc-link { display: block; font-family: 'Courier New', monospace; border-left: 2px solid transparent; transition: all 0.15s; }
.toc-link.h2 { font-size: 0.8rem; color: var(--text-2); padding: 0.3rem 0.75rem; }
.toc-link.h3 { font-size: 0.73rem; color: var(--text-3); padding: 0.18rem 1.5rem; }
.toc-link:hover { color: var(--red); border-left-color: var(--red); }

.breadcrumb { font-size: 0.74rem; color: var(--text-3); font-family: 'Courier New', monospace; margin-bottom: 1.75rem; }
.note-header { margin-bottom: 2rem; padding-bottom: 1.25rem; border-bottom: 1px solid var(--border); }
.note-header h1 { font-size: clamp(1.5rem, 3vw, 2rem); margin-bottom: 0.75rem; }
.note-meta { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
.meta-tags { display: flex; gap: 0.5rem; } /* 微调间距 */

.note-footer { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
.back-link { color: var(--red); font-family: 'Courier New', monospace; }
</style>