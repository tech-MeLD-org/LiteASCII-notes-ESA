---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.svelte';
import Footer from '../components/layout/Footer.svelte';
import PageHeader from '../components/layout/PageHeader.svelte';
import Pill from '../components/ui/Pill.svelte';
import { getCollection } from 'astro:content';
import { pathToSlug, getNoteTitle, isVisibleNote } from '../utils/note-logic';

const rawNotes = await getCollection('notes');
const allNotes = rawNotes.filter(n => 
  isVisibleNote(n) && 
  !n.data.tags?.some(t => t.toLowerCase() === 'thoughts')
);

const datedNotes = allNotes.filter(n => n.data.date).sort((a, b) => new Date(b.data.date!).getTime() - new Date(a.data.date!).getTime());
const undatedNotes = allNotes.filter(n => !n.data.date).sort((a, b) => getNoteTitle(a).localeCompare(getNoteTitle(b)));

const byYear = new Map<number, typeof datedNotes>();
for (const note of datedNotes) {
  const year = new Date(note.data.date!).getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(note);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Layout title="Timeline · LiteASCII">
  <Header client:load />
  <main class="pt-[calc(52px+2.5rem)] max-w-3xl mx-auto px-6 pb-16">
    <PageHeader 
      client:load
      title="Timeline" 
      subtitle="知识积累的时间轴 · A chronological map of ideas" 
    />

    {years.length > 0 && (
      <div class="mb-12">
        {years.map(year => (
          <section class="mb-8">
            <div class="text-sm font-mono font-bold text-primary tracking-wider mb-4">{year}</div>
            <div class="space-y-4">
              {byYear.get(year)!.map(note => {
                const date = new Date(note.data.date!);
                const monthDay = date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });
                const href = '/notes/' + pathToSlug(note.id);
                const noteTags = note.data.tags || [];
                const displayTags = noteTags.slice(0, 4);
                
                return (
                  <article class="flex gap-0 relative">
                    <div class="flex flex-col items-center w-14 flex-shrink-0">
                      <time class="text-xs text-text-muted font-mono text-center py-1 whitespace-nowrap">{monthDay}</time>
                      <div class="flex-1 w-px bg-border-color mt-1"></div>
                    </div>
                    <div class="flex-1 pb-4 pl-3">
                      <div class="flex flex-col p-3.5 bg-bg-card border border-border-color rounded-lg transition-all hover:border-primary hover:-translate-y-0.5 min-h-20">
                        <a href={href} class="text-[0.95rem] font-semibold mb-2 line-clamp-2 hover:text-primary transition-colors">
                          {getNoteTitle(note)}
                        </a>
                        
                        <div class="flex items-center gap-2 flex-wrap mt-auto">
                          {note.data.category && (
                            <Pill client:load variant="category" size="sm" href={`/category/${note.data.category}`}>{note.data.category}</Pill>
                          )}
                          {displayTags.map(tag => (
                            <Pill client:load variant="tag" size="sm" href={`/tags/${tag}`}>#{tag}</Pill>
                          ))}
                          {noteTags.length > 4 && (
                            <span class="text-xs text-primary font-mono bg-primary-faint px-1.5 py-0.5 rounded">+{noteTags.length - 4}</span>
                          )}
                          <span class="text-xs text-primary font-mono opacity-0 transition-opacity ml-auto group-hover:opacity-100">阅读 →</span>
                        </div>
                      </div>
                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        ))}
      </div>
    )}

    {undatedNotes.length > 0 && (
      <section class="border-t border-border-color pt-8">
        <h2 class="text-sm font-semibold text-text-secondary mb-4">未标日期的笔记</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {undatedNotes.map(note => (
            <a href={'/notes/' + pathToSlug(note.id)} class="flex flex-col p-3 bg-bg-card border border-border-color rounded transition-colors hover:border-primary">
              <span class="text-sm font-medium">{getNoteTitle(note)}</span>
              <span class="text-xs text-text-muted mt-1">{note.id.includes('/') ? note.id.split('/').slice(0, -1).join('/') : 'root'}</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
  <Footer />
</Layout>