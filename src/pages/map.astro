---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.svelte';
import Footer from '../components/layout/Footer.svelte';
import ReferenceGraph from '../components/graph/ReferenceGraph.svelte';
import DirectoryGraph from '../components/graph/DirectoryGraph.svelte';
import PageHeader from '../components/layout/PageHeader.svelte';
import { getCollection } from 'astro:content';
import { isVisibleNote, buildDirectoryTree, buildReferenceGraph } from '../utils/note-logic';

const allNotes = await getCollection('notes');
const validNotes = allNotes.filter(isVisibleNote);

const dirTreeData = buildDirectoryTree(validNotes);
const refGraphData = buildReferenceGraph(validNotes);
---

<Layout title="Knowledge Atlas · LiteASCII">
  <Header client:load />

  <main class="pt-[52px] h-screen flex flex-col max-w-[1400px] mx-auto px-6">
    <div class="py-6">
      <PageHeader
        client:load
        title="Knowledge Atlas"
        subtitle="探索层级结构与思维关联"
      />
    </div>

    <div class="flex gap-5 flex-1 min-h-0 mb-8 flex-col lg:flex-row">
      <!-- 中间目录图谱 -->
      <section class="flex-1 min-w-0 border border-border-color rounded-2xl bg-bg-card relative overflow-hidden min-h-[400px] lg:min-h-0">
        <DirectoryGraph client:only="svelte" data={dirTreeData} />
      </section>

      <!-- 右侧引用图谱 -->
      <aside class="w-full lg:w-80 flex-shrink-0 border border-border-color rounded-2xl bg-bg-card flex flex-col items-center p-6 min-h-[320px] lg:min-h-0">
        <div class="flex-1 w-full flex items-center justify-center">
          <ReferenceGraph 
            client:only="svelte" 
            nodes={refGraphData.nodes} 
            edges={refGraphData.edges} 
            size={280} 
          />
        </div>
        <span class="mt-4 text-xs tracking-wider text-text-muted font-mono uppercase">Reference Graph</span>
      </aside>
    </div>
  </main>

  <Footer />
</Layout>