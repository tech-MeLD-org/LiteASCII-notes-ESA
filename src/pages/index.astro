---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.svelte';
import AsciiArt from '../components/AsciiArt.svelte';
import ProfileCard from '../components/ProfileCard.astro';
import PostCard from '../components/PostCard.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');

const sorted = [...allNotes].sort((a, b) => {
  const da = a.data.date ? new Date(a.data.date).getTime() : 0;
  const db = b.data.date ? new Date(b.data.date).getTime() : 0;
  return db - da;
});

const recent = sorted.slice(0, 6);

// 统计数据
const noteCount = allNotes.length;

// 统计 Tags 和 Categories（与 notes 页面一致）
const tagCounts: Record<string, number> = {};
const categoryCounts: Record<string, number> = {};

allNotes.forEach((note: any) => {
  (note.data.tags || []).forEach((tag: string) => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
  if (note.data.category) {
    categoryCounts[note.data.category] = (categoryCounts[note.data.category] || 0) + 1;
  }
});

const allTags = Object.keys(tagCounts).sort((a, b) => tagCounts[b] - tagCounts[a]);
const allCategories = Object.keys(categoryCounts).sort((a, b) => categoryCounts[b] - categoryCounts[a]);

function getTitle(note: any) {
  if (note.data.title) return note.data.title;
  const match = note.body?.match(/^#\s+(.+)/m);
  if (match) return match[1].trim();
  return note.id.replace(/\.md$/, '').split('/').pop() || 'Untitled';
}

function noteSlug(note: any) { return note.id.replace(/\.md$/, ''); }
---

<Layout title="LiteASCII">
  <Navigation client:load />
  
  <div class="page-container">
    <div class="main-layout">
      
      <!-- 左侧边栏 -->
      <aside class="sidebar">
        <!-- Profile -->
        <div class="sidebar-box">
          <ProfileCard />
        </div>

        <!-- Categories -->
        <div class="sidebar-box">
          <h3 class="box-title">CATEGORIES</h3>
          <ul class="category-list" id="category-list">
            <li class="category-item">
              <a href="/notes" class="category-link">
                <span class="cat-name">全部</span>
                <span class="cat-count">{noteCount}</span>
              </a>
            </li>
            {allCategories.map((cat, index) => (
              <li class:list={['category-item', { 'is-hidden': index >= 6 }]}>
                <a href={`/category/${cat}`} class="category-link">
                  <span class="cat-name">{cat}</span>
                  <span class="cat-count">{categoryCounts[cat]}</span>
                </a>
              </li>
            ))}
          </ul>
          {allCategories.length > 6 && (
            <button id="cat-toggle-btn" class="toggle-btn">... 更多</button>
          )}
        </div>

        <!-- Tags -->
        <div class="sidebar-box">
          <h3 class="box-title">TAGS</h3>
          <div class="tags-list">
            {allTags.map(t => (
              <a href={`/tags/${t}`} class="tag-item">
                <span class="tag-symbol">#</span>{t}
                <span class="tag-num">{tagCounts[t]}</span>
              </a>
            ))}
          </div>
        </div>
      </aside>

      <!-- 右侧内容区 -->
      <main class="content-area">
        <!-- ASCII 动画 Hero -->
        <section class="hero-section">
          <div class="hero-ascii">
            <AsciiArt client:only="svelte" noteCount={noteCount} />
          </div>
          <div class="hero-stats">
            <div class="stat-item">
              <span class="stat-value">{noteCount}</span>
              <span class="stat-label">Notes</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">{allCategories.length}</span>
              <span class="stat-label">Categories</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">{allTags.length}</span>
              <span class="stat-label">Tags</span>
            </div>
          </div>
        </section>

        <!-- Recent Notes -->
        <section class="notes-section">
          <div class="section-header">
            <h2 class="section-title">Recent Notes</h2>
            <a href="/notes" class="section-more">All notes →</a>
          </div>
          
          {noteCount === 0 ? (
            <p class="empty-msg">将 Obsidian 笔记放入 <code>src/content/</code> 即可显示</p>
          ) : (
            <div class="notes-grid">
              {recent.map(note => (
                <PostCard
                  title={getTitle(note)}
                  href={'/notes/' + noteSlug(note)}
                  date={note.data.date}
                  description={note.data.description}
                  tags={note.data.tags}
                  category={note.data.category} 
                />
              ))}
            </div>
          )}
        </section>
      </main>
      
    </div>
  </div>

  <Footer />
</Layout>

<script>
  // Categories 展开/收起功能
  const toggleBtn = document.getElementById('cat-toggle-btn');
  const categoryList = document.getElementById('category-list');
  
  if (toggleBtn && categoryList) {
    toggleBtn.addEventListener('click', () => {
      const isExpanded = categoryList.classList.toggle('is-expanded');
      toggleBtn.textContent = isExpanded ? '收起 ∧' : '... 更多';
    });
  }
</script>

<style>
  .page-container { 
    margin-top: var(--nav-h); 
    padding: 2.5rem 1rem;
  }
  
  .main-layout { 
    display: flex; 
    width: 100%; 
    max-width: 1200px; 
    margin: 0 auto; 
    gap: 2.5rem; 
    align-items: flex-start;
  }

  /* ── 左侧边栏 ── */
  .sidebar { 
    width: 260px; 
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .sidebar-box { 
    border: 1px solid var(--border); 
    border-radius: 12px; 
    padding: 1.25rem;
    background: var(--bg);
  }

  /* ── 右侧内容区 ── */
  .content-area { 
    flex: 1; 
    min-width: 0; 
    padding-bottom: 2rem;
  }

  /* Hero 区域 */
  .hero-section {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg);
    padding: 2rem;
    margin-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .hero-ascii {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 200px;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    width: 100%;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    font-family: 'Courier New', monospace;
  }

  .stat-label {
    font-size: 0.7rem;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Notes 区域 */
  .notes-section { 
    padding: 0; 
  }
  
  .section-header { 
    display: flex; 
    align-items: baseline; 
    justify-content: space-between; 
    margin-bottom: 1.25rem;
    border-left: 3px solid var(--red);
    padding-left: 1rem;
  }
  
  .section-title { 
    font-size: 1.1rem; 
    font-weight: 700; 
    color: var(--text); 
    margin: 0; 
    letter-spacing: -0.01em;
  }
  
  .section-more { 
    font-size: 0.8rem; 
    color: var(--red); 
    font-family: 'Courier New', monospace; 
    text-decoration: none;
    transition: all 0.15s; 
  }
  
  .section-more:hover { 
    color: var(--text); 
    transform: translateX(2px);
  }
  
  .notes-grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
    gap: 1rem; 
  }
  
  .empty-msg { 
    font-size: 0.85rem; 
    color: var(--text-3); 
    padding: 2rem; 
    text-align: center; 
    border: 1px dashed var(--border); 
    border-radius: 8px; 
    background: var(--bg);
  }
  
  .empty-msg code { 
    font-family: 'Courier New', monospace; 
    color: var(--red); 
    background: var(--red-faint); 
    padding: 2px 6px; 
    border-radius: 4px; 
  }

  /* Categories & Tags 样式 */
  .box-title { 
    font-size: 0.7rem; 
    font-weight: 700; 
    color: var(--text-3); 
    margin: 0 0 1rem; 
    letter-spacing: 0.12em; 
    opacity: 0.8; 
    text-transform: uppercase;
  }

  .category-list { 
    list-style: none; 
    padding: 0; 
    margin: 0; 
    display: flex; 
    flex-direction: column; 
    gap: 0.15rem; 
  }
  
  .category-item.is-hidden {
    display: none;
  }
  
  .category-list.is-expanded .category-item.is-hidden {
    display: block;
    animation: fadeIn 0.25s ease;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .category-link {
    display: flex; 
    justify-content: space-between; 
    align-items: center;
    padding: 0.45rem 0.6rem; 
    color: var(--text-2); 
    text-decoration: none;
    border-radius: 6px; 
    font-size: 0.85rem; 
    transition: all 0.2s;
  }
  .category-link:hover { 
    background: var(--bg-2); 
    color: var(--text); 
  }
  
  .cat-name { font-weight: 500; }
  .cat-count { 
    font-size: 0.7rem; 
    color: var(--text-3); 
    font-family: 'Courier New', monospace; 
  }

  .toggle-btn {
    width: 100%; 
    background: none; 
    border: none; 
    padding: 0.6rem 0 0;
    text-align: left; 
    font-size: 0.75rem; 
    color: var(--text-3);
    cursor: pointer; 
    transition: color 0.2s;
    margin-top: 0.3rem;
  }
  .toggle-btn:hover { color: var(--red); }

  .tags-list { 
    display: flex; 
    flex-wrap: wrap; 
    gap: 0.5rem; 
  }
  
  .tag-item {
    display: inline-flex; 
    align-items: center; 
    gap: 0.2rem;
    padding: 0.3rem 0.6rem; 
    background: var(--bg-2); 
    border: 1px solid transparent;
    border-radius: 16px; 
    font-size: 0.75rem; 
    color: var(--text-2);
    text-decoration: none; 
    transition: all 0.2s;
  }
  .tag-item:hover { 
    border-color: var(--border); 
    background: var(--bg); 
    color: var(--text); 
  }
  
  .tag-symbol { 
    color: var(--text-3); 
    opacity: 0.6; 
    margin-right: 0.1rem;
  }
  .tag-num { 
    font-size: 0.65rem; 
    color: var(--text-3); 
    font-family: 'Courier New', monospace; 
    opacity: 0.7;
    margin-left: 0.2rem;
  }

  /* ── 移动端适配 ── */
  @media (max-width: 900px) {
    .main-layout { 
      flex-direction: column; 
      gap: 2rem;
    }
    
    .sidebar { 
      width: 100%;
    }
    
    .sidebar-box {
      position: static;
    }
    
    .hero-section {
      padding: 1.5rem;
    }
    
    .hero-ascii {
      min-height: 160px;
    }
    
    .hero-stats {
      gap: 1.5rem;
    }
    
    .stat-value {
      font-size: 1.2rem;
    }
  }

  @media (max-width: 640px) {
    .notes-grid {
      grid-template-columns: 1fr;
    }
  }
</style>