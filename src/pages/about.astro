---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.svelte';
import Footer from '../components/layout/Footer.svelte';
import PageHeader from '../components/layout/PageHeader.svelte';
---

<Layout title="About · LiteASCII">
  <Header client:load />

  <main class="pt-[calc(52px+2.5rem)] max-w-3xl mx-auto px-6 pb-16">
    <PageHeader 
      client:load
      title="About" 
      subtitle="关于这个知识空间" 
    />

    <article class="prose max-w-none">
      <h2 class="text-xl font-bold text-text-main mb-4">LiteASCII</h2>
      <p class="text-text-secondary mb-6">
        LiteASCII 是一个个人知识库网站，让知识在连接中生长。
      </p>

      <h2 class="text-xl font-bold text-text-main mb-4">技术栈</h2>
      <ul class="list-disc list-inside text-text-secondary mb-6 space-y-2">
        <li><strong class="text-text-main">Astro</strong> — 静态站点生成器</li>
        <li><strong class="text-text-main">Svelte</strong> — 交互组件（图谱、导航）</li>
        <li><strong class="text-text-main">Tailwind CSS</strong> — 样式系统</li>
        <li><strong class="text-text-main">Pagefind</strong> — 全文搜索</li>
      </ul>

      <h2 class="text-xl font-bold text-text-main mb-4">笔记说明</h2>
      <p class="text-text-secondary">
        笔记需存放于 <code class="text-primary bg-primary-faint px-1.5 py-0.5 rounded font-mono">src/content/</code>，保持 Obsidian 原生目录结构。
        附件图片统一放在笔记同级的 <code class="text-primary bg-primary-faint px-1.5 py-0.5 rounded font-mono">attachments/</code> 文件夹中。
      </p>
    </article>
  </main>

  <Footer />
</Layout>